# UltraClaw — Required Environment Variables
# Copy relevant lines to your ~/.bashrc or ~/.zshrc

# REQUIRED if using Claude (anthropic/*): get at console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# REQUIRED if using Gemini (google/*): get at aistudio.google.com/apikey
# OpenClaw reads GOOGLE_GENERATIVE_AI_API_KEY first, then falls back to GOOGLE_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here

# REQUIRED for web-search skill: Brave Search API (free tier at brave.com/search/api)
BRAVE_API_KEY=your-brave-api-key-here

# OPTIONAL: ElevenLabs for voice TTS (get at elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
